NODE_ENV=development
PORT=5050
APP_NAME="TaskHub API"
API_VERSION=v1
APP_URL=http://localhost:5173
API_URL=http://localhost:5050

# Random string used to sign HTTP-only cookies (PKCE verifier during Google OAuth).
COOKIE_SECRET=""

SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_AVATAR_BUCKET="avatars"

# Google sign-in:
# Enable the Google provider in Supabase Dashboard > Authentication > Providers.
# Add `${API_URL}/api/v1/auth/google/callback` and `${APP_URL}/auth/callback`
# to Supabase > Authentication > URL Configuration > Redirect URLs.
# No GOOGLE_CLIENT_ID/SECRET is required here; Supabase handles the Google handshake.