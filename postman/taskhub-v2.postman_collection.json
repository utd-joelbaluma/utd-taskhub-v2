{
  "info": {
    "name": "TaskHub v2",
    "description": "API collection for TaskHub v2 backend. Set the `baseUrl` and `token` variables before running requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5050",
      "type": "string"
    },
    {
      "key": "apiVersion",
      "value": "v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Bearer token from login response"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "invitationId",
      "value": "",
      "type": "string"
    },
    {
      "key": "profileId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Root",
      "item": [
        {
          "name": "Server Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Returns the app name and API version. No auth required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "health"]
            },
            "description": "Returns the health status of the server. No auth required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.user) {",
                  "    pm.collectionVariables.set('profileId', json.data.user.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "register"]
            },
            "description": "Create a new user account. Returns the created profile."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.access_token) {",
                  "    pm.collectionVariables.set('token', json.data.access_token);",
                  "  }",
                  "  if (json.data && json.data.user) {",
                  "    pm.collectionVariables.set('profileId', json.data.user.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "login"]
            },
            "description": "Authenticate with email and password. Saves `token` and `profileId` to collection variables on success."
          },
          "response": []
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "me"]
            },
            "description": "Returns the authenticated user's profile. Requires Bearer token."
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "logout"]
            },
            "description": "Invalidates the current session. Clears `token` variable on success."
          },
          "response": []
        },
        {
          "name": "Google Sign-In (Not Implemented)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "google"]
            },
            "description": "Placeholder for Google OAuth sign-in. Returns 501 Not Implemented."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects"],
              "query": [
                {
                  "key": "status",
                  "value": "active",
                  "description": "Filter by status: active | completed | archived",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search by project name (case-insensitive)",
                  "disabled": true
                }
              ]
            },
            "description": "Returns all projects. Optional query params: `status` and `search`."
          },
          "response": []
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects", "{{projectId}}"]
            },
            "description": "Returns a single project by its UUID."
          },
          "response": []
        },
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('projectId', json.data.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My New Project\",\n  \"description\": \"A short project description.\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects"]
            },
            "description": "Creates a new project. Saves `projectId` to collection variables on success.\n\nRequired: `name`\nOptional: `description`, `status` (default: active) — values: active | completed | archived"
          },
          "response": []
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Project Name\",\n  \"description\": \"Updated description.\",\n  \"status\": \"archived\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects", "{{projectId}}"]
            },
            "description": "Partially updates a project. All fields are optional.\n\n`name`: string (min 2 chars)\n`description`: string or null\n`status`: active | completed | archived"
          },
          "response": []
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects", "{{projectId}}"]
            },
            "description": "Permanently deletes a project by its UUID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Project Invitations",
      "item": [
        {
          "name": "List Project Invitations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects/{{projectId}}/invitations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects", "{{projectId}}", "invitations"],
              "query": [
                {
                  "key": "status",
                  "value": "pending",
                  "description": "Filter by status: pending | accepted | cancelled | expired",
                  "disabled": true
                }
              ]
            },
            "description": "Returns all invitations for a project. Requires auth and project membership."
          },
          "response": []
        },
        {
          "name": "Send Invitation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.invitation && json.data.invitation.id) {",
                  "    pm.collectionVariables.set('invitationId', json.data.invitation.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"invitee@example.com\",\n  \"role\": \"member\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects/{{projectId}}/invitations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects", "{{projectId}}", "invitations"]
            },
            "description": "Sends an email invitation to join a project. Requires auth and owner/manager role.\n\nRequired: `email`\nOptional: `role` (default: member) — values: owner | manager | member | viewer\n\nSaves `invitationId` on success."
          },
          "response": []
        },
        {
          "name": "Cancel Invitation",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects/{{projectId}}/invitations/{{invitationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects", "{{projectId}}", "invitations", "{{invitationId}}"]
            },
            "description": "Cancels a pending invitation. Requires auth and owner/manager role."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Invitations",
      "item": [
        {
          "name": "Accept Invitation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<invitation-token-from-email>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/invitations/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "invitations", "accept"]
            },
            "description": "Accepts an invitation using the token from the invitation email. Public endpoint — no auth required.\n\nPossible outcomes:\n- 200: Accepted and added to project\n- 200 + requires_registration: true — user must register first\n- 400: Invitation cancelled\n- 404: Invalid token\n- 409: Already a member or already accepted\n- 410: Invitation expired"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Profiles",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/profiles/{{profileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "profiles", "{{profileId}}"]
            },
            "description": "Returns a user profile by UUID. Requires auth."
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Doe\",\n  \"avatar_url\": \"https://example.com/avatar.png\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/profiles/{{profileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "profiles", "{{profileId}}"]
            },
            "description": "Updates a user profile. Users can update their own profile only. Admins can also update `role` and `status`.\n\nRegular fields: `full_name`, `avatar_url`\nAdmin-only fields: `role`, `status`"
          },
          "response": []
        },
        {
          "name": "Update Profile (Admin — role + status)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/profiles/{{profileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "profiles", "{{profileId}}"]
            },
            "description": "Admin-only variant. Updates `role` and/or `status` on any profile. The authenticated user must have role: admin.\n\n`role`: admin | manager | developer | user\n`status`: active | invited | disabled"
          },
          "response": []
        }
      ]
    }
  ]
}
